{
  "security_policy_file": "defaults/security_policy.json",
  "error_catalog_file": "defaults/error_catalog.json",
  "providers_schema_file": "defaults/providers.schema.json",
  "persistence": {
    "sqlite_path": "../var/bulkhead-lm.sqlite",
    "busy_timeout_ms": 5000
  },
  "virtual_keys": [
    {
      "name": "local-dev",
      "token_plaintext": "sk-bulkhead-lm-dev",
      "daily_token_budget": 50000,
      "requests_per_minute": 30,
      "allowed_routes": [
        "gpt-5",
        "gpt-5-mini",
        "gpt-5-nano",
        "claude-opus",
        "claude-sonnet",
        "claude-haiku",
        "gemini-2.5-pro",
        "gemini-2.5-flash",
        "gemini-2.5-flash-lite",
        "mistral-medium",
        "mistral-small",
        "codestral",
        "qwen-max",
        "qwen-plus",
        "qwen-turbo",
        "kimi-latest",
        "kimi-k2",
        "kimi-k2.5"
      ]
    }
  ],
  "routes": [
    {
      "public_model": "gpt-5",
      "backends": [
        {
          "provider_id": "openai-gpt-5",
          "provider_kind": "openai_compat",
          "upstream_model": "gpt-5",
          "api_base": "https://api.openai.com/v1",
          "api_key_env": "OPENAI_API_KEY"
        }
      ]
    },
