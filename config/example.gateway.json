{
  "security_policy_file": "defaults/security_policy.json",
  "error_catalog_file": "defaults/error_catalog.json",
  "providers_schema_file": "defaults/providers.schema.json",
  "persistence": {
    "sqlite_path": "../var/aegislm.sqlite",
    "busy_timeout_ms": 5000
  },
  "virtual_keys": [
    {
      "name": "local-dev",
      "token_plaintext": "sk-aegis-dev",
      "daily_token_budget": 50000,
      "requests_per_minute": 30,
      "allowed_routes": [
        "gpt-5-mini",
        "claude-sonnet",
        "gemini-2.5-flash",
        "qwen-plus",
        "kimi-k2.5"
      ]
    }
  ],
  "routes": [
    {
      "public_model": "gpt-5-mini",
      "backends": [
        {
          "provider_id": "openai-primary",
          "provider_kind": "openai_compat",
          "upstream_model": "gpt-5-mini",
          "api_base": "https://api.openai.com/v1",
          "api_key_env": "OPENAI_API_KEY"
        }
      ]
    },
    {
      "public_model": "claude-sonnet",
      "backends": [
        {
          "provider_id": "anthropic-primary",
          "provider_kind": "anthropic",
          "upstream_model": "claude-sonnet-4-5-20250929",
          "api_base": "https://api.anthropic.com/v1",
          "api_key_env": "ANTHROPIC_API_KEY"
        }
      ]
    },
    {
      "public_model": "gemini-2.5-flash",
      "backends": [
        {
          "provider_id": "google-primary",
          "provider_kind": "google_openai",
          "upstream_model": "gemini-2.5-flash",
          "api_base": "https://generativelanguage.googleapis.com/v1beta/openai/",
          "api_key_env": "GOOGLE_API_KEY"
        }
      ]
    },
    {
      "public_model": "qwen-plus",
      "backends": [
        {
          "provider_id": "alibaba-primary",
          "provider_kind": "alibaba_openai",
          "upstream_model": "qwen-plus",
          "api_base": "https://dashscope-intl.aliyuncs.com/compatible-mode/v1",
          "api_key_env": "DASHSCOPE_API_KEY"
        }
      ]
    },
    {
      "public_model": "kimi-k2.5",
      "backends": [
        {
          "provider_id": "moonshot-primary",
          "provider_kind": "moonshot_openai",
          "upstream_model": "kimi-k2.5",
          "api_base": "https://api.moonshot.ai/v1",
          "api_key_env": "MOONSHOT_API_KEY"
        }
      ]
    }
  ]
}
