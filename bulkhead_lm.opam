opam-version: "2.0"
synopsis: "Secure OCaml LLM gateway with OpenAI-compatible endpoints"
description:
  "A hierarchical, security-first OCaml LLM gateway with routing, budgets, virtual keys, and provider adapters."
maintainer: ["Louis-Ph"]
authors: ["Louis-Ph"]
license: "Apache-2.0"
homepage: "https://github.com/Louis-Ph/bulkhead-lm"
bug-reports: "https://github.com/Louis-Ph/bulkhead-lm/issues"
depends: [
  "ocaml"
  "dune" {>= "3.21"}
  "lwt"
  "yojson"
  "uri"
  "cohttp-lwt-unix"
  "tls-lwt"
  "sqlite3"
  "cmdliner"
  "linenoise"
  "logs"
  "fmt"
  "x509"
  "mirage-crypto-ec"
  "digestif"
  "uuidm"
  "base64"
  "alcotest" {with-test}
  "alcotest-lwt" {with-test}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
  [
    "dune"
    "build"
    "-p"
    name
    "-j"
    jobs
    "@install"
    "@runtest" {with-test}
    "@doc" {with-doc}
  ]
]
dev-repo: "git+https://github.com/Louis-Ph/bulkhead-lm.git"
